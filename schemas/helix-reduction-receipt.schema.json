{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "helix-reduction-receipt/1.0",
  "title": "HELIX novelty reduction receipt (post-implementation machine reduction)",
  "type": "object",
  "required": ["schema", "policy_version", "cohort_id", "cohort_commitment_sha256", "candidate_id", "parent_receipt_sha256", "novelty_claim", "implementation", "verdict", "receipt_sha256"],
  "properties": {
    "schema": {"type": "string", "enum": ["helix-reduction-receipt/1.0"]},
    "policy_version": {"type": "string", "enum": ["HELIX-HOLDOUT/1.0"]},
    "cohort_id": {"type": "string"},
    "cohort_commitment_sha256": {"type": "string"},
    "candidate_id": {"type": "string"},
    "parent_receipt_sha256": {"type": "string"},
    "novelty_claim": {
      "type": "object",
      "required": ["action", "machines"],
      "properties": {
        "action": {"type": "string", "enum": ["CONDENSE", "DEFER"]},
        "machines": {"type": "array", "items": {"type": "string"}}
      }
    },
    "implementation": {
      "type": "object",
      "required": ["implemented", "evidence_path", "evidence_sha256", "estimated_cost_units", "reduced_to_existing", "reduced_to"],
      "properties": {
        "implemented": {"type": "boolean"},
        "evidence_path": {"type": ["string", "null"]},
        "evidence_sha256": {"type": ["string", "null"]},
        "estimated_cost_units": {"type": "number", "minimum": 0},
        "reduced_to_existing": {"type": ["boolean", "null"]},
        "reduced_to": {"type": ["array", "null"], "items": {"type": "string"}}
      }
    },
    "verdict": {"type": "string", "enum": ["novel_confirmed", "reduced_to_existing", "not_implemented"]},
    "receipt_sha256": {"type": "string"}
  }
}
