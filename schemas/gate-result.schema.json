{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "helix-gate-result/1.0",
  "title": "HELIX Constitution authorization gate result",
  "type": "object",
  "required": ["schema", "policy_version", "decision", "risk_class", "reasons", "intent_digest", "evidence_manifest_sha256", "state_receipt_hash", "valid_approvers", "result_sha256"],
  "properties": {
    "schema": {"type": "string", "enum": ["helix-gate-result/1.0"]},
    "policy_version": {"type": "string", "enum": ["HELIX-CONSTITUTION/1.0"]},
    "decision": {"type": "string", "enum": ["ALLOW", "SANDBOX", "HUMAN", "DENY", "RETIRE"]},
    "risk_class": {"type": "string", "enum": ["R0", "R1", "R2", "R3"]},
    "reasons": {"type": "array", "items": {"type": "string"}},
    "intent_digest": {"type": "string"},
    "evidence_manifest_sha256": {"type": ["string", "null"]},
    "state_receipt_hash": {"type": "string"},
    "valid_approvers": {"type": "array", "items": {"type": "string"}},
    "result_sha256": {"type": "string"}
  }
}
