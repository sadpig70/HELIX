{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HELIX loop state (input to next_action)",
  "type": "object",
  "properties": {
    "last_engine": {"type": ["string", "null"], "enum": ["explore", "exploit", null]},
    "diversity": {"type": "object", "properties": {"triggered": {"type": "boolean"}}},
    "corpus_size": {"type": "integer", "minimum": 0},
    "pending_implemented_winner": {"type": "boolean"},
    "winner_in_ledger": {"type": "boolean"}
  }
}
